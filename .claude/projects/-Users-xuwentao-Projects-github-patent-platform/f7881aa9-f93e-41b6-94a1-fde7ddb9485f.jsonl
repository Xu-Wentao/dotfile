{"parentUuid":"1972c8a1-2dd4-46dd-9bb4-27870e2d608f","isSidechain":false,"promptId":"982ffb07-e402-4b03-8ee2-1e5de1eef3ab","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R5xH34iaJmJp2imevJTiSp","type":"tool_result","content":"1\t#!/bin/sh\n2\tinput=$(cat)\n3\tcwd=$(echo \"$input\" | jq -r '.workspace.current_dir // .cwd // \"unknown\"')\n4\tmodel=$(echo \"$input\" | jq -r '.model.display_name // \"unknown\"')\n5\tused=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty')\n6\t\n7\t# Shorten home directory to ~\n8\thome=\"$HOME\"\n9\tshort_cwd=$(echo \"$cwd\" | sed \"s|^$home|~|\")\n10\t\n11\t# Get git branch (skip locks)\n12\tbranch=\"\"\n13\tif git -C \"$cwd\" rev-parse --git-dir >/dev/null 2>&1; then\n14\t  branch=$(git -C \"$cwd\" -c gc.auto=0 symbolic-ref --short HEAD 2>/dev/null)\n15\tfi\n16\t\n17\t# ANSI colors (dim-friendly)\n18\tCYAN=\"\\033[36m\"\n19\tYELLOW=\"\\033[33m\"\n20\tGREEN=\"\\033[32m\"\n21\tBLUE=\"\\033[34m\"\n22\tRESET=\"\\033[0m\"\n23\t\n24\t# Build output\n25\tif [ -n \"$branch\" ]; then\n26\t  dir_branch=\"${CYAN}${short_cwd}${RESET} ${YELLOW}${branch}${RESET}\"\n27\telse\n28\t  dir_branch=\"${CYAN}${short_cwd}${RESET}\"\n29\tfi\n30\t\n31\tif [ -n \"$used\" ]; then\n32\t  printf \"${dir_branch}  ${BLUE}${model}${RESET}  ${GREEN}ctx:$(printf '%.0f' \"$used\")%%${RESET}\"\n33\telse\n34\t  printf \"${dir_branch}  ${BLUE}${model}${RESET}\"\n35\tfi\n36\t\n[result-id: r1]"}]},"uuid":"d737ac8d-3a08-4316-875e-eb88a2e9e9a1","timestamp":"2026-04-07T15:42:39.390Z","toolUseResult":{"type":"text","file":{"filePath":"/Users/xuwentao/.claude/statusline-command.sh","content":"#!/bin/sh\ninput=$(cat)\ncwd=$(echo \"$input\" | jq -r '.workspace.current_dir // .cwd // \"unknown\"')\nmodel=$(echo \"$input\" | jq -r '.model.display_name // \"unknown\"')\nused=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty')\n\n# Shorten home directory to ~\nhome=\"$HOME\"\nshort_cwd=$(echo \"$cwd\" | sed \"s|^$home|~|\")\n\n# Get git branch (skip locks)\nbranch=\"\"\nif git -C \"$cwd\" rev-parse --git-dir >/dev/null 2>&1; then\n  branch=$(git -C \"$cwd\" -c gc.auto=0 symbolic-ref --short HEAD 2>/dev/null)\nfi\n\n# ANSI colors (dim-friendly)\nCYAN=\"\\033[36m\"\nYELLOW=\"\\033[33m\"\nGREEN=\"\\033[32m\"\nBLUE=\"\\033[34m\"\nRESET=\"\\033[0m\"\n\n# Build output\nif [ -n \"$branch\" ]; then\n  dir_branch=\"${CYAN}${short_cwd}${RESET} ${YELLOW}${branch}${RESET}\"\nelse\n  dir_branch=\"${CYAN}${short_cwd}${RESET}\"\nfi\n\nif [ -n \"$used\" ]; then\n  printf \"${dir_branch}  ${BLUE}${model}${RESET}  ${GREEN}ctx:$(printf '%.0f' \"$used\")%%${RESET}\"\nelse\n  printf \"${dir_branch}  ${BLUE}${model}${RESET}\"\nfi\n","numLines":36,"startLine":1,"totalLines":36}},"sourceToolAssistantUUID":"1972c8a1-2dd4-46dd-9bb4-27870e2d608f","userType":"external","entrypoint":"cli","cwd":"/Users/xuwentao/Projects/github/patent-platform","sessionId":"f7881aa9-f93e-41b6-94a1-fde7ddb9485f","version":"2.1.92","gitBranch":"main","slug":"abstract-churning-whisper"}
